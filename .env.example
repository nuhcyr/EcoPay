# Spring profile
SPRING_PROFILES_ACTIVE=prod

# Supabase PostgreSQL connection
# Example: jdbc:postgresql://db.<project-ref>.supabase.co:5432/postgres?sslmode=require
DB_URL=jdbc:postgresql://db.<project-ref>.supabase.co:5432/postgres?sslmode=require
DB_USERNAME=postgres
DB_PASSWORD=your-supabase-db-password

# JWT
# Use at least 32+ characters
JWT_SECRET=replace-with-very-long-random-secret-key
JWT_ACCESS_TOKEN_MINUTES=30
JWT_REFRESH_TOKEN_DAYS=7

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Server
SERVER_PORT=8080
